# Development files
.vscode/**
.vscode-test/**
.claude/**
.git/**
.gitignore
.DS_Store

# Python cache files (CRITICAL - these bloat the package)
**/__pycache__/**
**/*.pyc
**/*.pyo
**/*.pyd

# Build configs
tsconfig.json
tsconfig.test.json
.mocharc.json
webpack.config.js

# Source files (only dist/ is needed)
src/**
test/**

# Dependencies are bundled into dist/extension.js via webpack - exclude node_modules
node_modules/**

# Build artifacts
*.vsix
vsix_archive/**

# Documentation (development only)
docs/**
saved_notes/**
scripts/**
CLAUDE.md
DOCUMENTATION_REVIEW.md
CUSTOM_RENDERER_IMPLEMENTATION.md
HARDWARE_CONFIG_TEMPLATE.md
INSTALL_FRESH.md
LESSON_11_FIX.md
LESSON_11_SUMMARY.md
LESSON_12_TT_XLA.md
LESSON_METADATA.md
NEXT_STEPS.md
PHASE_3_SUMMARY.md
RELEASE_READINESS_CHECKLIST.md
STYLING_GUIDE.md
TEST_STATUS.md
TEST_SUMMARY.md

# Vendor reference repos (NOT deployed with extension)
vendor/**

# BINARIES AND ARCHIVES (primary scanner triggers)
*.zip
*.tar.gz
*.tar
*.patch
*.diff
*.mp4

# CONTAINER / DEPLOYMENT FILES (moving to sister repo eventually)
Dockerfile*
.dockerignore
docker-compose.yml
podman-compose.yml
koyeb.yaml
.env*

# DEV ARTIFACTS
tmp/**
.backups/**
.github/**
.husky/**

# SOURCE ASSETS (already in dist/assets/ via copy-content — deduplication)
assets/**

# SOURCE CONTENT (already in dist/content/ via copy-content — deduplication)
content/**

# UNREFERENCED LARGE SAMPLE IMAGES IN DIST (not referenced in any lesson)
dist/assets/img/samples/frame_*.png

# Large dist GIF exclusions (prevent copy-content output from being packaged)
dist/assets/img/samples/particle_life_multi_device.gif
dist/assets/img/particle_life.gif
dist/assets/img/game_of_life.gif

# Misc dev docs not useful to users
VLLM_INSTALLATION_DRIFT.md
TT_METAL_PRECOMPILED.md
COMMUNITY_GUIDELINES.md
SECURITY.md
LICENSE_understanding.txt
experience_notes.md
MULTI_DEVICE_FIX.md
CODE_OF_CONDUCT.md
CONTRIBUTING.md

# Backup files
*.bak
*.log
*.tmp

# Package manager
package-lock.json
